{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "secure": {
      "format": "%(asctime)s - %(name)s - %(levelname)s - [REDACTED]"
    }
  },
  "handlers": {
    "file": {
      "class": "logging.handlers.RotatingFileHandler",
      "filename": "~/.nanobot/logs/nanobot.log",
      "maxBytes": 10485760,
      "backupCount": 5,
      "formatter": "secure",
      "encoding": "utf-8"
    }
  },
  "loggers": {
    "nanobot": {
      "handlers": ["file"],
      "level": "INFO"
    }
  }
}